# Gmail SMTP credentials (use an App Password, not your actual password)
EMAIL_FROM=your.email@gmail.com
EMAIL_TO=your.email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Alpha Vantage API (free tier — for supplemental fundamental data)
ALPHA_VANTAGE_API_KEY=your_key_here

# Tiingo API key (optional — for reliable daily incremental OHLCV updates)
# Free tier: 1000 req/day, 500 req/hour, 500 unique symbols/month
# Power User ($10/mo): 50000 req/day — recommended for full universe
# Get your key at: https://www.tiingo.com
TIINGO_API_KEY=your_key_here

# Optional: override default cache directory
CACHE_DIR=.cache
